# ===========================================
# SIGAH - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# Database (PostgreSQL connection string for Prisma)
DATABASE_URL=postgresql://<user>:<password>@localhost:5432/<database>

# Authentication (secret for signing JWT tokens)
JWT_SECRET=

# Server
PORT=3000
NODE_ENV=development

# Seed (optional - only required for: npx prisma db seed)
ADMIN_EMAIL=admin@sigah.gov.co
ADMIN_PASSWORD=
