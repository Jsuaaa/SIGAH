    USER {
        bigint id PK
        string email UK
        string name
        enum role
        bool is_active
        int failed_login_attempts
        datetime locked_until
        bool password_must_change
    }
    AUDIT_LOG {
        bigint id PK
        string action
        string module
        bigint entity_id
        bigint user_id FK
        jsonb before
        jsonb after
        inet ip_address
        datetime created_at
    }
    SCORING_CONFIG {
        string key PK
        decimal value
        bigint updated_by FK
        datetime updated_at
    }
    ALERT_THRESHOLD {
        bigint id PK
        bigint resource_type_id FK
        int min_quantity
        bigint updated_by FK
    }
    ZONE {
        bigint id PK
        string name UK
        enum risk_level
        decimal latitude
        decimal longitude
        int estimated_population
    }
    SHELTER {
        bigint id PK
        string name
        bigint zone_id FK
        enum type
        int max_capacity
        int current_occupancy
        decimal latitude
        decimal longitude
    }
    FAMILY {
        bigint id PK
        string family_code UK
        string head_document
        bigint zone_id FK
        bigint shelter_id FK
        int num_members
        decimal priority_score
        jsonb priority_score_breakdown
        enum status
        decimal latitude
        decimal longitude
    }
    PERSON {
        bigint id PK
        bigint family_id FK
        string name
        string document UK
        date birth_date
        enum relationship
        array special_conditions
        bool requires_medication
    }
    PRIVACY_CONSENT {
        bigint id PK
        bigint family_id FK
        datetime accepted_at
        bigint accepted_by_user_id FK
        string law_version
        inet ip_address
    }
    WAREHOUSE {
        bigint id PK
        string name UK
        bigint zone_id FK
        decimal max_capacity_kg
        decimal current_weight_kg
        enum status
        decimal latitude
        decimal longitude
    }
    RESOURCE_TYPE {
        bigint id PK
        string name
        enum category
        string unit_of_measure
        decimal unit_weight_kg
        bool is_active
    }
    INVENTORY {
        bigint id PK
        bigint warehouse_id FK
        bigint resource_type_id FK
        int available_quantity
        decimal total_weight_kg
        string batch
        date expiration_date
    }
    INVENTORY_ADJUSTMENT {
        bigint id PK
        bigint inventory_id FK
        int delta
        enum reason
        string reason_note
        bigint user_id FK
        datetime created_at
    }
    DONOR {
        bigint id PK
        string name
        enum type
        string contact
        string tax_id
    }
    DONATION {
        bigint id PK
        string donation_code UK
        bigint donor_id FK
        bigint destination_warehouse_id FK
        enum donation_type
        decimal monetary_amount
        datetime date
    }
    DONATION_DETAIL {
        bigint id PK
        bigint donation_id FK
        bigint resource_type_id FK
        int quantity
        decimal weight_kg
    }
    DISTRIBUTION_PLAN {
        bigint id PK
        string plan_code UK
        bigint created_by FK
        enum status
        enum scope
        bigint scope_id
        datetime created_at
    }
    DISTRIBUTION_PLAN_ITEM {
        bigint id PK
        bigint plan_id FK
        bigint family_id FK
        bigint source_warehouse_id FK
        int target_coverage_days
        enum status
        bigint delivery_id FK
    }
    DELIVERY {
        bigint id PK
        string delivery_code UK
        bigint family_id FK
        bigint source_warehouse_id FK
        bigint delivered_by FK
        bigint exception_authorized_by FK
        datetime delivery_date
        int coverage_days
        enum status
        decimal delivery_latitude
        decimal delivery_longitude
        string client_op_id UK
    }
    DELIVERY_DETAIL {
        bigint id PK
        bigint delivery_id FK
        bigint resource_type_id FK
        int quantity
        decimal weight_kg
    }
    HEALTH_VECTOR {
        bigint id PK
        enum vector_type
        enum risk_level
        enum status
        string actions_taken
        decimal latitude
        decimal longitude
        bigint zone_id FK
        bigint shelter_id FK
        bigint reported_by FK
        datetime reported_date
    }
    RELOCATION {
        bigint id PK
        bigint family_id FK
        bigint origin_shelter_id FK
        bigint destination_shelter_id FK
        enum type
        datetime relocation_date
        string reason
        bigint authorized_by FK
    }
